RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

PASS=0; WARN=0; FAIL=0

section()   { echo ""; echo -e "${BOLD}${BLUE}══════════════════════════════════════════${RESET}"; echo -e "${BOLD}${BLUE}  $1${RESET}"; echo -e "${BOLD}${BLUE}══════════════════════════════════════════${RESET}"; }
pass()      { echo -e "  ${GREEN}✅ PASS${RESET}  $1"; ((PASS++)); }
warn()      { echo -e "  ${YELLOW}⚠️  WARN${RESET}  $1"; ((WARN++)); }
fail()      { echo -e "  ${RED}❌ FAIL${RESET}  $1"; ((FAIL++)); }
info()      { echo -e "  ${DIM}     ℹ️   $1${RESET}"; }
recommend() { echo -e "  ${CYAN}     💡 建议：$1${RESET}"; }

# ============================================================
# 钱包扩展检查公共函数
# check_browser_wallet <钱包名> <扩展ID>
# ============================================================
check_browser_wallet() {
    local NAME="$1"
    local EXT_ID="$2"
    local FOUND_ANY=0
    local BROWSERS=(
        "$HOME/.config/google-chrome/Default/Local Extension Settings"
        "$HOME/.config/google-chrome/Profile 1/Local Extension Settings"
        "$HOME/.config/chromium/Default/Local Extension Settings"
        "$HOME/.config/brave-browser/Default/Local Extension Settings"
        "$HOME/.config/microsoft-edge/Default/Local Extension Settings"
    )
    for BROWSER_DIR in "${BROWSERS[@]}"; do
        local EXT_PATH="$BROWSER_DIR/$EXT_ID"
        if [ -d "$EXT_PATH" ]; then
            local SIZE
            SIZE=$(du -sh "$EXT_PATH" 2>/dev/null | cut -f1)
            local BROWSER_NAME
            BROWSER_NAME=$(echo "$BROWSER_DIR" | grep -oP '(?<=/\.config/)[^/]+')
            warn "${NAME} 钱包数据目录已发现（${BROWSER_NAME}，大小：${SIZE}）"
            info "路径：$EXT_PATH"
            recommend "${NAME} 扩展数据是 TrapDoor 重点目标，确保浏览器为最新版本，助记词已用硬件备份"
            FOUND_ANY=1
        fi
    done
    # Firefox 检查（扫描所有 profile）
    if [ -d "$HOME/.mozilla/firefox" ]; then
        local FF_EXT
        FF_EXT=$(find "$HOME/.mozilla/firefox" -maxdepth 4 -type d -name "*.default*" 2>/dev/null)
        if [ -n "$FF_EXT" ]; then
            # Firefox 用 UUID 而非扩展 ID，通过扩展名称目录匹配
            local FF_WALLET
            FF_WALLET=$(find "$HOME/.mozilla/firefox" -maxdepth 6 -type d 2>/dev/null | grep -i "$(echo "$NAME" | tr '[:upper:]' '[:lower:]')" | head -3)
            if [ -n "$FF_WALLET" ]; then
                warn "${NAME} Firefox 扩展数据疑似存在"
                echo "$FF_WALLET" | while read -r p; do info "路径：$p"; done
                FOUND_ANY=1
            fi
        fi
    fi
    if [ "$FOUND_ANY" -eq 0 ]; then
        pass "${NAME}：未发现浏览器钱包数据"
    fi
}

# ============================================================
# CLI / 开发者钱包检查公共函数
# check_cli_wallet <名称> <目录或文件路径> <建议文字>
# ============================================================
check_cli_wallet() {
    local NAME="$1"
    local PATH_PATTERN="$2"
    local ADVICE="$3"
    # 支持通配符展开
    local FOUND
    FOUND=$(eval "ls -d $PATH_PATTERN 2>/dev/null" | head -5)
    if [ -n "$FOUND" ]; then
        local FILE_COUNT
        FILE_COUNT=$(eval "find $PATH_PATTERN -type f 2>/dev/null" | wc -l)
        warn "${NAME} 钱包/密钥目录已发现（含 ${FILE_COUNT} 个文件）"
        echo "$FOUND" | while read -r p; do info "路径：$p"; done
        recommend "$ADVICE"
    else
        pass "${NAME}：未发现本地钱包文件"
    fi
}

