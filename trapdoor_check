AI_FOUND=0
for f in "${AI_FILES[@]}"; do
    FULL_PATH="$HOME/$f"
    if [ -f "$FULL_PATH" ]; then
        HIDDEN=$(cat -v "$FULL_PATH" 2>/dev/null | grep -P '[\x00-\x08\x0b\x0e-\x1f\x7f]|\^[A-Z\[\\\]^_`]')
        if [ -n "$HIDDEN" ]; then
            fail "文件 $f 中发现隐藏字符，可能已被注入恶意指令！"
            recommend "立即删除该文件：rm ~/$f，并检查 git 历史是否有异常提交"
        else
            warn "文件 $f 存在，内容正常（无隐藏字符）"
            info "文件路径：$FULL_PATH"
            recommend "定期检查此文件内容，确保没有被未知来源的包修改"
