section "5/9  SSH 安全检查"
if [ -f ~/.ssh/authorized_keys ]; then
    LINE_COUNT=$(grep -c . ~/.ssh/authorized_keys 2>/dev/null || echo 0)
    if [ "$LINE_COUNT" -eq 0 ]; then pass "authorized_keys 为空，无远程登录后门"
    else
        warn "authorized_keys 中有 $LINE_COUNT 条公钥记录"
        cat ~/.ssh/authorized_keys | while read -r line; do info "$line"; done
        recommend "确认每一条公钥都是你本人添加的，删除不认识的公钥"
    fi
else
    pass "authorized_keys 文件不存在，无后门风险"
fi
PRIVATE_KEYS=$(find ~/.ssh -type f ! -name "*.pub" ! -name "authorized_keys" ! -name "known_hosts" ! -name "config" 2>/dev/null)
if [ -z "$PRIVATE_KEYS" ]; then
    pass "未发现 SSH 私钥文件"
    info "如需使用 SSH，建议生成 ed25519 密钥：ssh-keygen -t ed25519"
else
    warn "发现 SSH 私钥文件"
    echo "$PRIVATE_KEYS" | while read -r k; do info "$k"; done
    recommend "确认私钥设有密码保护：ssh-keygen -y -f <私钥路径>"
fi

